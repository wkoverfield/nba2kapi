# ============================================================================
# CONVEX BACKEND CONFIGURATION
# ============================================================================
#
# IMPORTANT: Convex uses TWO different domains:
# - .convex.cloud = ConvexClient for realtime queries/mutations (WebSocket)
# - .convex.site  = HTTP Actions for REST API endpoints (fetch/curl)
#
# ============================================================================

# Convex deployment identifier
# Format: dev:deployment-name OR prod:deployment-name
CONVEX_DEPLOYMENT=dev:your-deployment

# CONVEX_URL - For ConvexHttpClient (scraper scripts, mutations)
# Uses .convex.cloud domain
CONVEX_URL=https://your-deployment.convex.cloud

# NEXT_PUBLIC_CONVEX_URL - For ConvexReactClient (frontend realtime subscriptions)
# Uses .convex.cloud domain
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# NEXT_PUBLIC_CONVEX_SITE_URL - For HTTP API calls (REST endpoints like /api/players)
# Uses .convex.site domain
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# ============================================================================
# API CONFIGURATION
# ============================================================================

# Admin API key for privileged operations (scraping, maintenance)
# Generate a secure random string (min 32 characters)
# SECURITY: Keep this secret! Never commit to version control
ADMIN_API_KEY=your_secure_admin_key_here

# Allowed CORS origin for API requests
# Production: https://yourdomain.com
# Development: http://localhost:3000
CLIENT_ORIGIN=http://localhost:3000

# Optional: Override API base URL for documentation
# NEXT_PUBLIC_API_BASE_URL=https://your-deployment.convex.site/api

# ============================================================================
# ENVIRONMENT
# ============================================================================

# Node environment (development | production | test)
NODE_ENV=development

# ============================================================================
# TESTING (Optional - only needed for performance/integration tests)
# ============================================================================

# API key for running performance tests
# Get from: Register at /api/register endpoint
# TEST_API_KEY=2k_your_test_api_key_here

# ============================================================================
# NOTES
# ============================================================================

# 1. Copy this file to .env.local: cp .env.example .env.local
# 2. Fill in all required values (marked as "your_...")
# 3. Never commit .env.local to version control
# 4. For production deployment, set these in your hosting platform's environment settings
#
# Example for production (canny-kingfisher-472):
#   CONVEX_URL=https://canny-kingfisher-472.convex.cloud
#   NEXT_PUBLIC_CONVEX_URL=https://canny-kingfisher-472.convex.cloud
#   NEXT_PUBLIC_CONVEX_SITE_URL=https://canny-kingfisher-472.convex.site
