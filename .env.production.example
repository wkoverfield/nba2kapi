# Production Environment Variables
# Set these in your Vercel dashboard under Settings > Environment Variables
#
# IMPORTANT: Convex uses TWO different domains:
# - .convex.cloud = ConvexClient for realtime queries/mutations
# - .convex.site  = HTTP Actions for REST API endpoints

# Convex Production Deployment
CONVEX_DEPLOYMENT=prod:canny-kingfisher-472

# CONVEX_URL - For ConvexHttpClient (scraper, backend scripts)
# Uses .convex.cloud domain (NOT custom domain - custom domains don't work with ConvexHttpClient)
CONVEX_URL=https://canny-kingfisher-472.convex.cloud

# NEXT_PUBLIC_CONVEX_URL - For ConvexReactClient (frontend realtime)
# Uses .convex.cloud domain
NEXT_PUBLIC_CONVEX_URL=https://canny-kingfisher-472.convex.cloud

# NEXT_PUBLIC_CONVEX_SITE_URL - For HTTP API calls (REST endpoints)
# Uses .convex.site domain - this is where /api/players etc. are served
NEXT_PUBLIC_CONVEX_SITE_URL=https://canny-kingfisher-472.convex.site

# API Configuration
# Generate a secure admin key: node -e "console.log('admin_' + require('crypto').randomBytes(32).toString('hex'))"
ADMIN_API_KEY=admin_YOUR_SECURE_KEY_HERE

# CORS Configuration
CLIENT_ORIGIN=https://nba2kapi.com

# Environment
NODE_ENV=production
